# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────
# Cloudflare R2
# ──────────────────────────────────────────────
# Endpoint: From R2 bucket → Settings → S3 API
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=candle-art-shop-images

# From: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL for your R2 bucket (enable "Public access" in R2 bucket settings)
# Format: https://pub-XXXX.r2.dev  OR  https://images.yourdomain.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ──────────────────────────────────────────────
# Admin credentials
# ──────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-secure
